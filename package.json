{
  "name": "turborepo-shadcn-ui",
  "version": "1.2.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "ui:add": "pnpm --filter @repo/ui ui:add",
    "dev:docker": "pnpm run prisma:docker && yarn dev",
    "prisma:docker": "cd packages/db && pnpm prisma db push --force-reset && pnpm prisma db seed",
    "start:web": "cd apps/web && pnpm run start"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^18.3.3",
    "prettier": "^3.3.2",
    "turbo": "latest"
  },
  "packageManager": "pnpm@8.9.0",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@google/generative-ai": "^0.2.1",
    "@icons-pack/react-simple-icons": "^9.5.0",
    "@nextui-org/dropdown": "^2.1.29",
    "@prisma/client": "^5.15.0",
    "@tiptap/core": "^2.1.7",
    "@tiptap/extension-color": "^2.1.7",
    "@tiptap/extension-highlight": "^2.1.7",
    "@tiptap/extension-horizontal-rule": "^2.1.7",
    "@tiptap/extension-image": "^2.1.7",
    "@tiptap/extension-link": "^2.1.7",
    "@tiptap/extension-placeholder": "^2.5.8",
    "@tiptap/extension-table": "^2.5.8",
    "@tiptap/extension-table-cell": "^2.5.8",
    "@tiptap/extension-table-header": "^2.5.8",
    "@tiptap/extension-table-row": "^2.5.8",
    "@tiptap/extension-task-item": "^2.1.7",
    "@tiptap/extension-task-list": "^2.1.7",
    "@tiptap/extension-text-style": "^2.1.7",
    "@tiptap/extension-underline": "^2.1.7",
    "@tiptap/react": "^2.1.7",
    "@tiptap/starter-kit": "^2.5.8",
    "@types/html-to-text": "^9.0.4",
    "ai": "^2.2.37",
    "html-to-text": "^9.0.5",
    "jspdf": "^2.5.1",
    "novel": "^0.5.0",
    "openai": "^4.4.0",
    "react-quill": "^2.0.0",
    "recoil": "^0.7.7",
    "tiptap-markdown": "^0.8.2"
  }
}
